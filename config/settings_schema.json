[
    {
        "name": "theme_info",
        "theme_name": "Carryboo Theme",
        "theme_version": "0.1.0",
        "theme_author": "Carryboo",
        "theme_support_email": "support@carryboo.com",
        "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes"
    },
    {
        "name": "Branding",
        "settings": [
            {
                "type": "image_picker",
                "id": "logo",
                "label": "Logo"
            },
            {
                "type": "range",
                "id": "logo_width",
                "min": 70,
                "max": 240,
                "step": 10,
                "default": 120,
                "unit": "px",
                "label": "Largeur du logo"
            },
            {
                "type": "image_picker",
                "id": "favicon",
                "label": "Favicon"
            }
        ]
    },
    {
        "name": "Typographie",
        "settings": [
            {
                "type": "font_picker",
                "id": "type_header_font",
                "default": "assistant_n7",
                "label": "Police des titres"
            },
            {
                "type": "font_picker",
                "id": "type_body_font",
                "default": "assistant_n4",
                "label": "Police du texte"
            }
        ]
    },
    {
        "name": "Couleurs",
        "settings": [
            {
                "type": "color",
                "id": "color_background",
                "label": "Fond global",
                "default": "#fffaf4"
            },
            {
                "type": "color",
                "id": "color_surface",
                "label": "Surface",
                "default": "#ffffff"
            },
            {
                "type": "color",
                "id": "color_text",
                "label": "Texte",
                "default": "#27231f"
            },
            {
                "type": "color",
                "id": "color_muted",
                "label": "Texte secondaire",
                "default": "#6f675d"
            },
            {
                "type": "color",
                "id": "color_primary",
                "label": "Couleur principale",
                "default": "#116853"
            },
            {
                "type": "color",
                "id": "color_accent",
                "label": "Accent",
                "default": "#f3a53b"
            },
            {
                "type": "color",
                "id": "color_border",
                "label": "Bordures",
                "default": "#e5dacc"
            }
        ]
    },
    {
        "name": "Mise en page",
        "settings": [
            {
                "type": "range",
                "id": "page_width",
                "min": 1000,
                "max": 1500,
                "step": 50,
                "default": 1200,
                "unit": "px",
                "label": "Largeur max du contenu"
            }
        ]
    }
]
