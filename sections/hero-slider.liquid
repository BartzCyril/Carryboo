{{ 'section-hero-slider.css' | asset_url | stylesheet_tag }}

<section
  class="hero-slider"
  role="region"
  aria-roledescription="carousel"
  aria-label="Slides principales"
  data-slider
>
  {%- for block in section.blocks -%}
    <article
      id="Slide-{{ section.id }}-{{ forloop.index0 }}"
      class="hero-slider__slide{% if forloop.first %} is-active{% endif %}"
      data-slide
      aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
      {{ block.shopify_attributes }}
    >
      {%- if block.settings.image -%}
        {%- if forloop.first -%}
          {{
            block.settings.image
            | image_url: width: 2200
            | image_tag:
              class: 'hero-slider__image',
              loading: 'eager',
              fetchpriority: 'high',
              preload: true,
              widths: '750, 1100, 1500, 1800, 2200',
              sizes: '100vw'
          }}
        {%- else -%}
          {{
            block.settings.image
            | image_url: width: 2200
            | image_tag:
              class: 'hero-slider__image',
              loading: 'lazy',
              widths: '750, 1100, 1500, 1800, 2200',
              sizes: '100vw'
          }}
        {%- endif -%}
      {%- endif -%}
      <div class="hero-slider__content wrapper">
        {%- if block.settings.heading != blank -%}
          <h1>{{ block.settings.heading }}</h1>
        {%- endif -%}
        {%- if block.settings.text != blank -%}
          <p>{{ block.settings.text }}</p>
        {%- endif -%}
        {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
          <a class="button button-primary button-large" href="{{ block.settings.button_link }}">
            {{ block.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </article>
  {%- endfor -%}

  {%- if section.blocks.size > 1 -%}
    {% render 'pagination-bullets', bullets: section.blocks.size, section_id: section.id, active_index: 0 %}
  {%- endif -%}
</section>

<script src="{{ 'slider.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Hero slider",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image de fond"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Les essentiels bebe livres simplement"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Sous-titre",
          "default": "<p>Composez votre routine, choisissez votre rythme, recevez vos produits a la maison.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Texte CTA",
          "default": "Voir les produits"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "URL du CTA"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slider"
    }
  ]
}
{% endschema %}
